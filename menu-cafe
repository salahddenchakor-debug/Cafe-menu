<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gueliz Café & Lounge — Menu</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #C9A84C;
            --gold-light: #E2C97E;
            --gold-dim: rgba(201,168,76,0.15);
            --black: #090909;
            --surface: #111111;
            --surface2: #191919;
            --border: rgba(201,168,76,0.2);
            --text: #E8E0D0;
            --muted: #7A7060;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--black);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            font-weight: 300;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* HEADER */
        header {
            width: 100%;
            max-width: 480px;
            padding: 40px 24px 28px;
            text-align: center;
            position: relative;
        }

        .logo-mark {
            display: inline-block;
            width: 48px;
            height: 1px;
            background: var(--gold);
            margin-bottom: 20px;
        }

        .cafe-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 36px;
            font-weight: 300;
            letter-spacing: 0.25em;
            color: var(--gold-light);
            text-transform: uppercase;
            line-height: 1;
        }

        .cafe-sub {
            font-size: 10px;
            letter-spacing: 0.3em;
            color: var(--muted);
            text-transform: uppercase;
            margin-top: 10px;
        }

        .divider {
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin-top: 28px;
            opacity: 0.4;
        }

        /* QR SECTION */
        .qr-section {
            width: calc(100% - 48px);
            max-width: 432px;
            margin: 20px 0;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .qr-wrap {
            background: white;
            padding: 8px;
            border-radius: 8px;
            flex-shrink: 0;
        }

        .qr-wrap img { display: block; width: 80px; height: 80px; }

        .qr-text h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 14px;
            color: var(--gold);
            font-weight: 600;
            margin-bottom: 4px;
        }

        .qr-text p {
            font-size: 11px;
            color: var(--muted);
            line-height: 1.5;
        }

        /* MENU */
        main {
            width: 100%;
            max-width: 480px;
            padding: 0 24px 120px;
            display: flex;
            flex-direction: column;
            gap: 32px;
        }

        .category-label {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .category-label span {
            font-family: 'Cormorant Garamond', serif;
            font-size: 20px;
            font-weight: 600;
            color: var(--gold-light);
            letter-spacing: 0.05em;
        }

        .category-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .item {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            transition: border-color 0.2s;
            margin-bottom: 10px;
        }

        .item:hover { border-color: var(--gold); }

        .item-name {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 5px;
            letter-spacing: 0.01em;
        }

        .item-desc {
            font-size: 11px;
            color: var(--muted);
            line-height: 1.6;
        }

        .item-price {
            font-family: 'Cormorant Garamond', serif;
            font-size: 17px;
            font-weight: 700;
            color: var(--gold);
            white-space: nowrap;
            background: var(--gold-dim);
            padding: 4px 10px;
            border-radius: 20px;
            flex-shrink: 0;
        }

        /* CTA */
        .cta-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 16px 24px;
            background: linear-gradient(to top, #090909 60%, transparent);
            display: flex;
            justify-content: center;
            z-index: 50;
        }

        .cta-btn {
            width: 100%;
            max-width: 432px;
            background: linear-gradient(135deg, #C9A84C 0%, #8B6914 100%);
            color: #090909;
            font-weight: 600;
            font-size: 13px;
            letter-spacing: 0.05em;
            text-decoration: none;
            text-align: center;
            padding: 16px 24px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 0 24px rgba(201,168,76,0.3);
            animation: glow 3s ease-in-out infinite;
        }

        @keyframes glow {
            0%, 100% { box-shadow: 0 0 20px rgba(201,168,76,0.25); }
            50% { box-shadow: 0 0 36px rgba(201,168,76,0.5); }
        }
    </style>
</head>
<body>

<header>
    <div class="logo-mark"></div>
    <div class="cafe-name">Gueliz Café</div>
    <div class="cafe-sub">Lounge & Gastronomie — Marrakech</div>
    <div class="divider"></div>
</header>

<div class="qr-section">
    <div class="qr-wrap">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=160x160&color=090909&bgcolor=ffffff&data=https://gueliz-cafe.ma/menu" alt="QR Menu">
    </div>
    <div class="qr-text">
        <h3>Scanner pour partager</h3>
        <p>Partagez ce menu avec vos amis — scannez le QR code avec votre téléphone.</p>
    </div>
</div>

<main>

    <!-- Petit Déjeuner -->
    <div>
        <div class="category-label"><span>Petit Déjeuner / الإفطار</span></div>

        <div class="item">
            <div>
                <div class="item-name">Formule Marrakechia</div>
                <div class="item-desc">Msemmen, Baghrir, Huile d'olive, Miel, Thé Marocain</div>
            </div>
            <div class="item-price">45 DH</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Express Gueliz</div>
                <div class="item-desc">Café au lait, Jus d'orange frais, Viennoiserie au choix</div>
            </div>
            <div class="item-price">35 DH</div>
        </div>
    </div>

    <!-- Boissons -->
    <div>
        <div class="category-label"><span>Boissons / المشروبات</span></div>

        <div class="item">
            <div>
                <div class="item-name">Café Crème Premium</div>
                <div class="item-desc">Grains sélectionnés, mousse de lait onctueuse</div>
            </div>
            <div class="item-price">22 DH</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Jus d'Avocat Royale</div>
                <div class="item-desc">Avocat frais, amandes pilées, éclats de dattes</div>
            </div>
            <div class="item-price">30 DH</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Thé à la Menthe</div>
                <div class="item-desc">Menthe fraîche de Marrakech, sucre traditionnel</div>
            </div>
            <div class="item-price">15 DH</div>
        </div>
    </div>

    <!-- Plats -->
    <div>
        <div class="category-label"><span>Plats / الوجبات</span></div>

        <div class="item">
            <div>
                <div class="item-name">Tagine Poulet aux Citrons</div>
                <div class="item-desc">Poulet beldi, olives de Marrakech, citrons confits</div>
            </div>
            <div class="item-price">75 DH</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Briouates au Fromage</div>
                <div class="item-desc">Feuilleté croustillant, fromage fondant, herbes fraîches</div>
            </div>
            <div class="item-price">40 DH</div>
        </div>
    </div>

</main>

<div class="cta-bar">
    <a class="cta-btn" href="https://maps.google.com" target="_blank">
        ⭐ Laissez-nous un avis 5 étoiles sur Google
    </a>
</div>

</body>
</html>
